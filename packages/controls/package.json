{
  "name": "@ar-framework/controls",
  "version": "1.0.0",
  "packageManager": "yarn@4.6.0",
  "dependencies": {
    "@ar-framework/ui": "file:../ui",
    "@ar-framework/utils": "file:../utils",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "immer": "^10.1.1",
    "mapbox-gl": "^3.10.0",
    "radix-ui": "^1.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.6",
    "zustand": "^5.0.3"
  },
  "scripts": {
    "copyAppToWebPublic": "cp -r dist/index.js ../../web/public/features/controls/index.js && cp -r dist/index.css ../../web/public/features/controls/index.css",
    "build": "dotenv -e ./.env.controls.production -- parcel build index.html --no-content-hash --no-source-maps && yarn copyAppToWebPublic",
    "build:dev": "dotenv -e ./.env.controls.development -- parcel build index.html --no-content-hash --no-source-maps && yarn copyAppToWebPublic",
    "start": "parcel index.html",
    "dev": "NODE_ENV=DEV parcel serve index.html"
  },
  "devDependencies": {
    "@parcel/config-default": "^2.14.2",
    "@parcel/core": "^2.14.2",
    "@tailwindcss/postcss": "^4.0.16",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "parcel": "^2.14.2",
    "parcel-namer-hashless": "^1.0.7",
    "postcss": "^8.2.1"
  }
}
